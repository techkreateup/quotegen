// ─── SAAS BILLING (Razorpay) ─────────────────────────────────────────────────
// Records platform subscription payments (a company paying US for the SaaS).
// Distinct from the in-app Subscription/SubscriptionPayment models, which track
// a tenant's own third-party vendor subscriptions.

model BillingPayment {
  id                String               @id @default(cuid())
  companyId         String
  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  razorpayOrderId   String               @unique
  razorpayPaymentId String?              @unique
  razorpaySignature String?
  // Stored in the smallest currency unit (paise for INR), as Razorpay returns it.
  amount            Int
  currency          String               @default("INR")
  status            BillingPaymentStatus @default(CREATED)
  // Plan the payment is for, and any extra context (e.g. webhook event id).
  planName          String?
  notes             Json                 @default("{}")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([companyId], map: "idx_billingpayment_company")
  @@index([status], map: "idx_billingpayment_status")
}

enum BillingPaymentStatus {
  CREATED
  CAPTURED
  FAILED
  REFUNDED
}

// Audit trail of inbound third-party webhooks (Razorpay today; structured to
// accept more providers later). Lets ops see what fired, whether the signature
// verified, the resulting HTTP status, and any handler error — without trawling
// Vercel logs.
model WebhookEvent {
  id           String   @id @default(cuid())
  provider     String // "razorpay" | future
  event        String // e.g. "payment.captured", "subscription.charged"
  signatureOk  Boolean // result of HMAC check
  responseCode Int // status we returned to the provider
  // Useful joinables when known: order/payment/company ids extracted from payload.
  orderId      String?
  paymentId    String?
  companyId    String?
  // Truncated payload + error trace for forensic debugging.
  payload      Json     @default("{}")
  error        String   @default("")
  createdAt    DateTime @default(now())

  @@index([provider, createdAt(sort: Desc)], map: "idx_webhookevent_provider")
  @@index([orderId], map: "idx_webhookevent_order")
  @@index([companyId], map: "idx_webhookevent_company")
}

// GST invoice issued to a company for a captured subscription payment (Sprint 2.5).
// Amounts are in rupees. SAC 9983 (IT/software services).
model SubscriptionInvoice {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billingPaymentId String   @unique
  invoiceNumber    String   @unique
  customerGstin    String   @default("")
  placeOfSupply    String   @default("")
  sacCode          String   @default("9983")
  taxableValue     Float
  cgst             Float    @default(0)
  sgst             Float    @default(0)
  igst             Float    @default(0)
  total            Float
  createdAt        DateTime @default(now())

  @@index([companyId], map: "idx_subinvoice_company")
}

// ─── DOCUMENT VAULT (Phase 2) ────────────────────────────────────────────────
// Company "memory": every business/HR/legal/payroll/compliance document, kept
// in one place, linkable to an employee/client/project, with optional expiry for
// licenses & certificates (drives renewal reminders + a compliance score).
model Document {
  id             String              @id @default(cuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Human-readable per-company reference (DOC-0001…), shown in the vault.
  code           String              @default("")
  name           String // display name (defaults to filename)
  fileUrl        String // UploadThing URL
  fileKey        String              @default("") // UploadThing key (for deletion)
  // Which storage pool (UploadThing account) holds this file. Lets the platform
  // scale past one account's quota by adding pools; deletion uses the right token.
  storagePool    String              @default("primary")
  mimeType       String              @default("")
  format         String              @default("") // pdf | docx | png | webp | ...
  sizeBytes      Int                 @default(0)
  // Onboarding | HR | Legal | Finance | Payroll | Compliance | Tax | Personal | Other
  category       String              @default("Other")
  description    String              @default("")
  expiresAt      DateTime? // licenses/certs that lapse
  // Optional entity links (plain ids, not FK-enforced to stay lightweight).
  employeeId     String?
  clientId       String?
  projectId      String?
  uploadedById   String?
  uploadedByName String              @default("")
  // Approval lifecycle. Default "approved" so plain uploads stay visible; only
  // documents explicitly submitted for approval move through pending/rejected.
  status         String              @default("approved") // draft | pending_approval | approved | rejected
  createdByRole  String              @default("")
  signatures     DocumentSignature[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([companyId])
  @@index([companyId, category])
  @@index([companyId, expiresAt])
  @@index([companyId, employeeId])
  @@index([companyId, status])
}

// ─── STORAGE POOLS (Phase 2 polish) ──────────────────────────────────────────
// Super-admin-managed UploadThing accounts. Each pool adds capacity; the token
// is stored encrypted (src/lib/crypto.ts). The env UPLOADTHING_TOKEN remains the
// always-present "primary" fallback. See src/lib/storage.ts.
model StoragePool {
  id         String   @id @default(cuid())
  name       String   @unique // lowercase identifier, e.g. "pool2"
  label      String   @default("") // friendly name shown in admin
  tokenEnc   String // AES-256-GCM encrypted UploadThing token
  capacityMb Int      @default(2048) // pool capacity in MB (2GB default)
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ─── DECISION ADVISOR (Phase 3) ───────────────────────────────────────────────
// Cross-tenant learning engine. Two planes (see src/lib/advisor/ + db.ts):
//   • LEARNING (global, unscoped background job): reads AdvisorEvent, publishes
//     AdvisorCohortStat — aggregates only, after k-anonymity + DP guards.
//   • SERVING (per-tenant request): reads the tenant's own rows + the global
//     AdvisorCohortStat, never another tenant's data.
// AdvisorEvent and AdvisorCohortStat are GLOBAL (not in TENANT_MODELS). Only
// AdvisorRecommendation is tenant-scoped.

// Append-only, de-identified outcome stream. No PII, no FK to Client/User/Company
// — only a one-way salted hash of the tenant, so a leak can't be re-identified
// and erasure (DPDP) can target a tenant's rows by hash.
model AdvisorEvent {
  id           String   @id @default(cuid())
  tenantHash   String // HMAC(companyId, ADVISOR_SALT)
  kind         String // "quote_outcome" (v1)
  // ── generalized cohort features ──
  industry     String   @default("")
  region       String   @default("") // client state (coarse; never city)
  currency     String   @default("INR")
  amountBucket String
  discountBand String
  quarter      String   @default("") // "2026-Q2" — seasonality / decay
  // ── outcome ──
  won          Boolean
  occurredAt   DateTime @default(now())

  @@index([kind, occurredAt])
  @@index([tenantHash])
}

// Published, served-back aggregate. One row per (kind, cohortKey, discountBand).
// Every row here has already cleared passesReleaseGate(); existence ⇒ safe.
model AdvisorCohortStat {
  id           String   @id @default(cuid())
  kind         String
  cohortKey    String // e.g. "L0:amt=10k-50k|currency=INR|industry=...|region=..."
  cohortLevel  Int // 0 = most specific … 4 = global (for evidence display)
  discountBand String
  wins         Int      @default(0) // DP-noised
  trials       Int      @default(0) // DP-noised
  tenantCount  Int      @default(0)
  epsilon      Float    @default(1.0) // DP budget spent on this row
  updatedAt    DateTime @updatedAt

  @@unique([kind, cohortKey, discountBand])
  @@index([kind])
}

// Per-tenant cached recommendation + feedback (Thompson-sampling-ready for 3.5).
model AdvisorRecommendation {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  kind      String // "quote_winprob"
  subjectId String // quotationId
  payload   Json // computed numbers + evidence (see recommend.ts)
  shownAt   DateTime?
  accepted  Boolean?
  outcome   String? // realized result, filled in later for the learning loop
  createdAt DateTime  @default(now())
  expiresAt DateTime

  @@index([companyId, subjectId])
  @@index([companyId, kind])
}

// ─── SAVED TEMPLATES (org-wide, versioned) ───────────────────────────────────
// A customized document template saved by a company for reuse. Org-wide (shared
// across the company's users) with version history.
model SavedTemplate {
  id            String                 @id @default(cuid())
  companyId     String
  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  category      String                 @default("Other") // HR | Legal | Onboarding | ...
  baseId        String // the built-in DOC_TEMPLATES id it was built from
  html          String // current customized body HTML
  version       Int                    @default(1)
  createdById   String?
  createdByName String                 @default("")
  createdByRole String                 @default("")
  // Designated signatories rendered into the document: [{ role, name, signatureId? }].
  signatories   Json                   @default("[]")
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  versions      SavedTemplateVersion[]

  @@index([companyId])
}

model SavedTemplateVersion {
  id              String        @id @default(cuid())
  savedTemplateId String
  savedTemplate   SavedTemplate @relation(fields: [savedTemplateId], references: [id], onDelete: Cascade)
  version         Int
  html            String
  createdByName   String        @default("")
  createdAt       DateTime      @default(now())

  @@index([savedTemplateId])
}

// ─── SIGNATURES (signing authority — distinct from approval authority) ────────
// Org-wide, role-tagged signature library (e.g. "CEO sign", "HR Manager sign").
// Reused on templates/documents. Other sources (CompanySettings sign slots and
// Employee.signatureUrl) are synthesized into the picker by the signatures API.
model Signature {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String // signer name, e.g. "Rajesh Kumar"
  role          String   @default("") // title/authority, e.g. "CEO"
  imageUrl      String // data-url or UploadThing url
  source        String   @default("manual") // manual | employee | settings
  employeeId    String?
  isActive      Boolean  @default(true)
  createdById   String?
  createdByName String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
}

// One row per signature applied to a document (a document may carry many).
model DocumentSignature {
  id                 String   @id @default(cuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documentId         String
  document           Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatureId        String? // library entry, when reused
  signerName         String   @default("")
  signerRole         String   @default("")
  imageUrl           String
  source             String   @default("manual") // template | approval | manual
  workflowApprovalId String?
  appliedById        String?
  appliedByName      String   @default("")
  appliedAt          DateTime @default(now())

  @@index([documentId])
  @@index([companyId])
}

// ─── COMMUNICATION & CADENCES (Track B) ──────────────────────────────────────
// Reusable templated messaging (email/WhatsApp) with merge fields + PDF attach,
// a unified send log, multi-step escalating cadences (dunning/follow-up), and a
// polymorphic follow-up task board. Backbone for every reminder/share/follow-up.

// A reusable message template. `body`/`subject`/`toExpr` may contain {{merge}}
// variables resolved per entity at send time (see src/lib/messaging.ts).
model MessageTemplate {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  category      String   @default("General") // Sales | Billing | Procurement | HR | General
  channel       String   @default("EMAIL")   // EMAIL | WHATSAPP | BOTH
  entityType    String   @default("")          // client | quotation | invoice | purchaseOrder | vendor | employee
  toExpr        String   @default("")          // literal address or {{merge}} (e.g. {{client.email}})
  ccExpr        String   @default("")
  bccExpr       String   @default("")
  subject       String   @default("")
  body          String   @default("")          // HTML with {{merge}} vars
  attachPdf     Boolean  @default(false)
  attachKind    String   @default("none")      // quote | invoice | po | grn | statement | none
  isSystem      Boolean  @default(false)        // seeded default template
  isActive      Boolean  @default(true)
  version       Int      @default(1)
  createdById   String?
  createdByName String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
}

// One row per dispatched (or attempted) message. Audit + "last sent" UI +
// idempotency: dedupeKey is set for automated cadence sends so a cron retry
// can't double-send. Manual sends leave it null (Postgres treats nulls as
// distinct, so the unique index permits many manual sends).
model MessageLog {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel    String // EMAIL | WHATSAPP
  templateId String?
  entityType String   @default("")
  entityId   String   @default("")
  toAddr     String   @default("")
  ccAddr     String   @default("")
  bccAddr    String   @default("")
  subject    String   @default("")
  body       String   @default("")
  status     String   @default("queued") // queued | sent | failed | delivered | skipped
  provider   String   @default("") // resend | whatsapp-cloud | dev
  providerId String   @default("")
  error      String   @default("")
  dedupeKey  String? // entity+cadenceStep+date for automated sends; null for manual
  sentById   String?
  sentByName String   @default("")
  sentAt     DateTime @default(now())

  @@unique([companyId, dedupeKey])
  @@index([companyId, entityType, entityId])
  @@index([companyId, status])
}

// A multi-step escalating sequence. Anchored to a date on the target entity
// (invoice due date, quote sent date, vendor bill due date). Auto-stops when the
// underlying condition clears (invoice paid, quote replied).
model Cadence {
  id          String              @id @default(cuid())
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  trigger     String // ar_dunning | quote_followup | vendor_payment_due | recurring_invoice | custom
  anchor      String              @default("dueDate") // dueDate | sentDate | billDate | custom
  entityType  String              @default("")
  isActive    Boolean             @default(true)
  isSystem    Boolean             @default(false)
  stopOnPaid  Boolean             @default(true)
  stopOnReply Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  steps       CadenceStep[]
  enrollments CadenceEnrollment[]

  @@index([companyId])
}

// Ordered step within a cadence. Reached only via the scoped parent Cadence, so
// it carries no companyId and is NOT a TENANT_MODEL (same pattern as WorkflowStep).
model CadenceStep {
  id         String  @id @default(cuid())
  cadenceId  String
  cadence    Cadence @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  stepOrder  Int     @default(0)
  offsetDays Int     @default(0) // ± days from the cadence anchor (e.g. -7, +1, +15)
  channel    String  @default("EMAIL")
  templateId String?
  condition  String  @default("") // optional gate, e.g. only-if-unpaid

  @@index([cadenceId])
}

// A target entity enrolled into a cadence, tracking which step is next and when.
// The daily cron advances `currentStep`/`nextRunAt` and dispatches due steps.
model CadenceEnrollment {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cadenceId   String
  cadence     Cadence   @relation(fields: [cadenceId], references: [id], onDelete: Cascade)
  entityType  String
  entityId    String
  currentStep Int       @default(0)
  nextRunAt   DateTime?
  status      String    @default("active") // active | paused | done | stopped
  anchorDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([companyId, cadenceId, entityType, entityId])
  @@index([companyId, status, nextRunAt])
}

// A polymorphic follow-up task spanning clients, quotes, sales/purchase orders,
// invoices and vendors. Powers the unified /follow-ups board + in-app reminders.
model FollowUp {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entityType       String // client | quotation | salesOrder | purchaseOrder | invoice | vendor
  entityId         String
  title            String    @default("")
  note             String    @default("")
  status           String    @default("open") // open | done | snoozed
  dueAt            DateTime?
  channel          String    @default("")
  assignedToId     String?
  assignedToName   String    @default("")
  lastMessageLogId String?
  createdById      String?
  createdByName    String    @default("")
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId, status, dueAt])
  @@index([companyId, entityType, entityId])
}
